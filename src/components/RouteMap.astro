---
import type { SplitKM } from '../data/logs';
interface Props {
  splits: SplitKM[];
  title: string;
}
const { splits, title } = Astro.props;
const hasSplits = splits.length > 0;

// Build a fake but plausible polyline route based on number of km.
const n = Math.max(splits.length, 1);
const points: [number, number][] = [];
let x = 80, y = 220;
for (let i = 0; i < n; i++) {
  const t = i / Math.max(n - 1, 1);
  // pseudo-random but stable shape
  const wob = Math.sin(t * Math.PI * 4) * 60;
  const rise = -t * 120 + Math.cos(t * 6) * 25;
  x = 60 + t * 480;
  y = 220 + wob * 0.6 + rise * 0.8;
  points.push([x, y]);
}
const pathD = points.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p[0].toFixed(1)} ${p[1].toFixed(1)}`).join(' ');
const start = points[0];
const end = points[points.length - 1];

// Pace bars
const paces = splits.map(s => {
  const [m, sec] = s.pace.split(':').map(Number);
  return m * 60 + sec;
});
const minP = Math.min(...paces);
const maxP = Math.max(...paces);
const range = Math.max(maxP - minP, 1);
---
<div class="rounded-2xl border border-ink-800 bg-gradient-to-br from-ink-900 to-ink-950 overflow-hidden">
  <div class="px-5 sm:px-6 pt-5 pb-3 flex items-baseline justify-between flex-wrap gap-2">
    <h2 class="font-display text-lg font-semibold text-ink-100">{title}</h2>
    {hasSplits && <p class="text-xs text-ink-400 font-mono-tnum">{splits.length} km · pace by split</p>}
  </div>
  {hasSplits ? (
    <>
      <div class="px-5 sm:px-6">
        <div class="relative rounded-xl overflow-hidden bg-ink-950 border border-ink-800 aspect-[16/8]" role="img" aria-label={`Map of run route — ${splits.length} kilometers, fictional rendering.`}>
          <!-- grid -->
          <svg viewBox="0 0 600 280" class="absolute inset-0 w-full h-full" aria-hidden="true">
            <defs>
              <pattern id="grid" width="32" height="32" patternUnits="userSpaceOnUse">
                <path d="M 32 0 L 0 0 0 32" fill="none" stroke="#1d2535" stroke-width="0.5"/>
              </pattern>
              <linearGradient id="routeGrad" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#c5ff3a"/>
                <stop offset="100%" stop-color="#ff5b14"/>
              </linearGradient>
            </defs>
            <rect width="600" height="280" fill="url(#grid)"/>
            <!-- shadow -->
            <path d={pathD} stroke="#000" stroke-width="6" fill="none" opacity="0.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d={pathD} stroke="url(#routeGrad)" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx={start[0]} cy={start[1]} r="6" fill="#c5ff3a" stroke="#07090d" stroke-width="2"/>
            <circle cx={end[0]} cy={end[1]} r="6" fill="#ff5b14" stroke="#07090d" stroke-width="2"/>
          </svg>
          <div class="absolute top-3 left-3 inline-flex items-center gap-1.5 text-[10px] font-mono-tnum bg-ink-950/80 border border-ink-700 rounded-md px-2 py-1 text-ink-200">
            <span class="w-2 h-2 rounded-full bg-volt-400"></span> START
          </div>
          <div class="absolute top-3 right-3 inline-flex items-center gap-1.5 text-[10px] font-mono-tnum bg-ink-950/80 border border-ink-700 rounded-md px-2 py-1 text-ink-200">
            END <span class="w-2 h-2 rounded-full bg-flame-500"></span>
          </div>
          <p class="absolute bottom-3 left-3 text-[10px] text-ink-400 font-mono-tnum bg-ink-950/70 rounded px-1.5 py-0.5">illustrative route render</p>
        </div>
      </div>

      <div class="px-5 sm:px-6 py-5">
        <p class="text-xs uppercase tracking-widest text-ink-400 font-semibold mb-3">Splits</p>
        <div class="flex gap-1 items-end h-28" role="img" aria-label="Pace per kilometer, lower bars are faster.">
          {splits.map((s, i) => {
            const t = (paces[i] - minP) / range;
            const heightPct = 25 + (1 - t) * 70;
            const isFast = t < 0.33;
            return (
              <div class="flex-1 flex flex-col items-center gap-1">
                <span class="text-[9px] text-ink-400 font-mono-tnum">{s.pace}</span>
                <div class="w-full bg-ink-800 rounded-t-sm overflow-hidden flex items-end" style="height:70%">
                  <div class={`bar-rise w-full ${isFast ? 'bg-flame-500' : 'bg-volt-400/70'}`} style={`height:${heightPct}%`}></div>
                </div>
                <span class="text-[9px] text-ink-500 font-mono-tnum">{s.km}</span>
              </div>
            );
          })}
        </div>
      </div>
    </>
  ) : (
    <div class="px-5 sm:px-6 pb-6">
      <div class="rounded-xl border border-dashed border-ink-700 bg-ink-950/50 px-5 py-8 text-center">
        <p class="font-display text-xl text-ink-200">Rest day — no run logged</p>
        <p class="mt-1 text-sm text-ink-400">Active recovery only. Nutrition still tracked.</p>
      </div>
    </div>
  )}
</div>
