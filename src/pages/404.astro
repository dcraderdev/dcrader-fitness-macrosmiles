---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Off the route" description="That page isn't on the route sheet. Head back to base and pick up the run.">
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 opacity-60 pointer-events-none" aria-hidden="true">
      <svg class="absolute -top-32 left-1/2 -translate-x-1/2 w-[900px] h-[900px] max-w-none" viewBox="0 0 600 600" fill="none">
        <circle cx="300" cy="300" r="220" stroke="#ff5b14" stroke-opacity="0.15" stroke-width="1"/>
        <circle cx="300" cy="300" r="260" stroke="#ff5b14" stroke-opacity="0.08" stroke-width="1"/>
        <circle cx="300" cy="300" r="180" stroke="#c5ff3a" stroke-opacity="0.12" stroke-width="1"/>
      </svg>
    </div>

    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-20 sm:py-28 text-center">
      <p class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.18em] text-volt-400 font-semibold mb-6">
        <span class="pulse-dot w-2 h-2 rounded-full bg-volt-400" aria-hidden="true"></span>
        Off the route sheet
      </p>

      <h1 class="font-display font-bold text-flame-500 leading-none tracking-tight text-[7rem] sm:text-[10rem] lg:text-[12rem] font-mono-tnum">
        404
      </h1>

      <h2 class="mt-2 font-display text-3xl sm:text-4xl font-bold text-ink-100 tracking-tight">
        Page not found
      </h2>

      <p class="mt-5 text-lg text-ink-200 max-w-xl mx-auto">
        Looks like this split didn't make the log. Maybe the URL took a wrong turn at mile 4, or the page is still in the cooldown queue. Either way — let's loop back to base.
      </p>

      <div class="mt-9 flex flex-wrap gap-3 justify-center">
        <a href="/" class="inline-flex items-center gap-2 bg-flame-500 text-ink-950 font-semibold px-5 py-3 rounded-lg hover:bg-flame-400 transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M19 12H5m6 6l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Back to home
        </a>
        <a href="/plan/" class="inline-flex items-center gap-2 border border-ink-700 hover:border-volt-400 text-ink-100 hover:text-volt-300 font-semibold px-5 py-3 rounded-lg transition-colors">
          View the plan
        </a>
      </div>

      <p class="mt-10 text-xs uppercase tracking-widest text-ink-400 font-mono-tnum">
        status: dnf &middot; retry recommended
      </p>
    </div>
  </section>
</Layout>
