---
import Layout from '../layouts/Layout.astro';
import MacroBar from '../components/MacroBar.astro';
import WeeklyChart from '../components/WeeklyChart.astro';
import { logs, weekly, paceFromSecPerKm } from '../data/logs';

const latest = logs[0];
const recent = logs.slice(0, 5);
---
<Layout title="Macros + Miles" description="A run+nutrition log for athletes. Track miles, macros, and recovery on the same page.">
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-ink-800">
    <div class="absolute inset-0 -z-10 opacity-60 pointer-events-none" aria-hidden="true">
      <svg class="absolute -top-20 -right-20 w-[720px] h-[720px]" viewBox="0 0 600 600" fill="none">
        <circle cx="300" cy="300" r="220" stroke="#ff5b14" stroke-opacity="0.15" stroke-width="1"/>
        <circle cx="300" cy="300" r="260" stroke="#ff5b14" stroke-opacity="0.08" stroke-width="1"/>
        <circle cx="300" cy="300" r="180" stroke="#c5ff3a" stroke-opacity="0.12" stroke-width="1"/>
      </svg>
    </div>
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-14 sm:pt-20 pb-12 sm:pb-16">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7">
          <p class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.18em] text-volt-400 font-semibold mb-5">
            <span class="pulse-dot w-2 h-2 rounded-full bg-volt-400"></span>
            Training week 11 · 18-week marathon block
          </p>
          <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-ink-100 leading-[1.05] tracking-tight">
            Miles in.<br/>
            <span class="text-flame-500">Macros</span> dialed.<br/>
            Race day on schedule.
          </h1>
          <p class="mt-6 text-lg text-ink-200 max-w-2xl">
            Macros + Miles is a daily log built for athletes who want their run data and their nutrition on the same page — not stitched across four apps.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href={`/log/${latest.slug}/`} class="inline-flex items-center gap-2 bg-flame-500 text-ink-950 font-semibold px-5 py-3 rounded-lg hover:bg-flame-400 transition-colors">
              See today's log
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/plan/" class="inline-flex items-center gap-2 border border-ink-700 hover:border-volt-400 text-ink-100 hover:text-volt-300 font-semibold px-5 py-3 rounded-lg transition-colors">
              View the plan
            </a>
          </div>
        </div>

        <!-- Hero stat card -->
        <div class="lg:col-span-5">
          <div class="rounded-2xl border border-ink-700 bg-ink-900/80 backdrop-blur p-6 shadow-2xl shadow-flame-500/10">
            <div class="flex items-center justify-between">
              <p class="text-xs uppercase tracking-widest text-ink-400 font-semibold">This week</p>
              <p class="text-xs text-ink-300 font-mono-tnum">May 10 — May 16</p>
            </div>
            <p class="mt-3 font-display text-5xl font-bold text-ink-100 font-mono-tnum">
              {weekly.totalKm}<span class="text-flame-500 text-2xl"> km</span>
            </p>
            <p class="text-sm text-ink-300 font-mono-tnum">avg pace {paceFromSecPerKm(weekly.avgPaceSecPerKm)} / km · {Math.floor(weekly.totalMin/60)}h {weekly.totalMin%60}m total</p>

            <div class="mt-6 grid grid-cols-3 gap-3 text-center">
              <div class="rounded-lg bg-ink-800/70 px-3 py-3">
                <p class="text-[10px] uppercase tracking-wider text-flame-400 font-semibold">Kcal</p>
                <p class="mt-1 font-display font-bold text-ink-100 font-mono-tnum">{weekly.totalKcal.toLocaleString()}</p>
              </div>
              <div class="rounded-lg bg-ink-800/70 px-3 py-3">
                <p class="text-[10px] uppercase tracking-wider text-volt-400 font-semibold">Sleep</p>
                <p class="mt-1 font-display font-bold text-ink-100 font-mono-tnum">{weekly.avgSleep}h</p>
              </div>
              <div class="rounded-lg bg-ink-800/70 px-3 py-3">
                <p class="text-[10px] uppercase tracking-wider text-ink-200 font-semibold">RHR</p>
                <p class="mt-1 font-display font-bold text-ink-100 font-mono-tnum">{weekly.avgRHR}</p>
              </div>
            </div>

            <div class="mt-6">
              <p class="text-xs uppercase tracking-widest text-ink-400 font-semibold mb-2">Week macros</p>
              <MacroBar protein={weekly.totalProtein} carbs={weekly.totalCarbs} fat={weekly.totalFat} compact />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Today preview -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14 sm:py-16">
    <div class="flex items-end justify-between flex-wrap gap-2 mb-8">
      <div>
        <p class="text-xs uppercase tracking-widest text-flame-400 font-semibold">Latest entry</p>
        <h2 class="mt-1 font-display text-3xl sm:text-4xl font-bold text-ink-100 tracking-tight">{latest.weekday} · {latest.run.title}</h2>
      </div>
      <a href={`/log/${latest.slug}/`} class="text-sm font-semibold text-volt-400 hover:text-volt-300 inline-flex items-center gap-1">
        Open detail
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </a>
    </div>

    <div class="grid lg:grid-cols-3 gap-5">
      <article class="lg:col-span-2 rounded-2xl border border-ink-800 bg-gradient-to-br from-ink-900 to-ink-950 p-6">
        <h3 class="text-sm uppercase tracking-widest text-ink-400 font-semibold mb-4">Run</h3>
        <div class="grid sm:grid-cols-4 gap-4 font-mono-tnum">
          <div><p class="text-[11px] uppercase tracking-wider text-ink-400">Distance</p><p class="font-display text-2xl font-bold text-ink-100">{latest.run.distanceKm} <span class="text-sm text-ink-400">km</span></p></div>
          <div><p class="text-[11px] uppercase tracking-wider text-ink-400">Pace</p><p class="font-display text-2xl font-bold text-ink-100">{latest.run.pace}</p></div>
          <div><p class="text-[11px] uppercase tracking-wider text-ink-400">Avg HR</p><p class="font-display text-2xl font-bold text-ink-100">{latest.run.avgHr}</p></div>
          <div><p class="text-[11px] uppercase tracking-wider text-ink-400">Elev</p><p class="font-display text-2xl font-bold text-ink-100">{latest.run.elevationM}m</p></div>
        </div>
        <p class="mt-5 text-sm text-ink-300">{latest.notes}</p>
      </article>

      <article class="rounded-2xl border border-ink-800 bg-gradient-to-br from-ink-900 to-ink-950 p-6">
        <h3 class="text-sm uppercase tracking-widest text-ink-400 font-semibold mb-4">Nutrition</h3>
        <p class="font-display text-3xl font-bold text-ink-100 font-mono-tnum">
          {latest.totalKcal.toLocaleString()}<span class="text-flame-500 text-lg"> kcal</span>
        </p>
        <p class="text-xs text-ink-400 font-mono-tnum mt-1">target {latest.targetKcal.toLocaleString()} · {Math.round((latest.totalKcal/latest.targetKcal)*100)}% hit</p>
        <div class="mt-5">
          <MacroBar protein={latest.macros.protein} carbs={latest.macros.carbs} fat={latest.macros.fat} compact />
        </div>
      </article>
    </div>
  </section>

  <!-- Weekly chart + recent list -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-14 sm:pb-20">
    <div class="grid lg:grid-cols-12 gap-6">
      <div class="lg:col-span-7">
        <WeeklyChart />
      </div>
      <div class="lg:col-span-5">
        <div class="rounded-2xl border border-ink-800 bg-gradient-to-br from-ink-900 to-ink-950 p-5 sm:p-6 h-full">
          <h2 class="font-display text-lg font-semibold text-ink-100 mb-4">Recent logs</h2>
          <ul class="divide-y divide-ink-800">
            {recent.map(l => (
              <li>
                <a href={`/log/${l.slug}/`} class="group flex items-center justify-between gap-3 py-3 hover:bg-ink-800/30 -mx-2 px-2 rounded-md transition-colors">
                  <div class="min-w-0">
                    <p class="text-xs uppercase tracking-wider text-ink-400 font-semibold">{l.weekday} · {l.date}</p>
                    <p class="text-sm text-ink-100 font-semibold truncate group-hover:text-flame-300">{l.run.title}</p>
                  </div>
                  <div class="text-right font-mono-tnum shrink-0">
                    <p class="text-sm text-ink-100 font-semibold">{l.run.distanceKm ? `${l.run.distanceKm} km` : 'rest'}</p>
                    <p class="text-xs text-ink-400">{l.totalKcal.toLocaleString()} kcal</p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA strip -->
  <section class="border-t border-ink-800 bg-gradient-to-r from-ink-950 via-ink-900 to-ink-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
      <div class="rounded-2xl border border-ink-800 bg-ink-900/60 p-8 sm:p-10 grid sm:grid-cols-3 gap-6 items-center">
        <div class="sm:col-span-2">
          <h2 class="font-display text-2xl sm:text-3xl font-bold text-ink-100 tracking-tight">Train heavy. Eat on purpose.</h2>
          <p class="mt-2 text-ink-300">See how the workout plan and the meal plan share a single calendar.</p>
        </div>
        <div class="flex sm:justify-end">
          <a href="/plan/" class="inline-flex items-center gap-2 bg-volt-400 text-ink-950 font-bold px-5 py-3 rounded-lg hover:bg-volt-300 transition-colors">
            Open the plan
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
