---
import Layout from '../layouts/Layout.astro';
import { week, mealPlan, dailyTargets } from '../data/plan';

const typeColor: Record<string, string> = {
  Long: 'bg-flame-500/15 text-flame-300 border-flame-500/30',
  Tempo: 'bg-flame-400/15 text-flame-300 border-flame-400/30',
  Intervals: 'bg-volt-400/15 text-volt-300 border-volt-400/30',
  Easy: 'bg-ink-700/40 text-ink-200 border-ink-600',
  Recovery: 'bg-ink-700/40 text-ink-200 border-ink-600',
  Rest: 'bg-ink-800/60 text-ink-400 border-ink-700',
  Strength: 'bg-volt-400/15 text-volt-300 border-volt-400/30',
};
---
<Layout title="Plan" description="Macros + Miles training plan — weekly workout schedule and meal plan on one screen.">
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-12 pb-8">
    <p class="text-xs uppercase tracking-widest text-volt-400 font-semibold">Week 11 · marathon block</p>
    <h1 class="mt-2 font-display text-4xl sm:text-5xl font-bold text-ink-100 tracking-tight">The Plan</h1>
    <p class="mt-4 text-ink-300 max-w-3xl text-lg">Training and nutrition aren't separate spreadsheets here. The workout calendar and the meal plan live on the same screen, so you can see fuel and effort together.</p>
  </section>

  <!-- Daily targets -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-10">
    <h2 class="font-display text-lg font-semibold text-ink-100 mb-4">Daily targets</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
      {dailyTargets.map(t => (
        <div class="rounded-xl border border-ink-800 bg-gradient-to-br from-ink-900 to-ink-950 px-4 py-4">
          <p class="text-[10px] uppercase tracking-wider text-ink-400 font-semibold">{t.label}</p>
          <p class="mt-1 font-display text-2xl font-bold text-ink-100 font-mono-tnum">{t.value}</p>
          <p class="text-[11px] text-ink-400 mt-0.5">{t.hint}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Weekly schedule -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-12">
    <div class="flex items-baseline justify-between flex-wrap gap-2 mb-5">
      <h2 class="font-display text-2xl font-bold text-ink-100">Training week</h2>
      <p class="text-xs text-ink-400 font-mono-tnum">{week.reduce((s, d) => s + d.distanceKm, 0)} km planned</p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-7 gap-3">
      {week.map(d => (
        <article class="rounded-xl border border-ink-800 bg-gradient-to-br from-ink-900 to-ink-950 p-4 flex flex-col">
          <div class="flex items-center justify-between">
            <p class="text-xs uppercase tracking-widest text-ink-400 font-semibold">{d.day}</p>
            <span class={`text-[10px] uppercase tracking-wider px-2 py-0.5 rounded-full border font-mono-tnum ${typeColor[d.type] ?? typeColor.Easy}`}>{d.type}</span>
          </div>
          <h3 class="mt-3 font-display font-bold text-ink-100 leading-tight">{d.title}</h3>
          <div class="mt-3 flex items-baseline gap-3 font-mono-tnum">
            <p class="font-display text-2xl font-bold text-flame-400">{d.distanceKm || '—'}<span class="text-xs text-ink-400 ml-0.5">{d.distanceKm ? 'km' : ''}</span></p>
            <p class="text-xs text-ink-400">{d.duration}</p>
          </div>
          <p class="mt-3 text-xs text-ink-300 leading-relaxed">{d.description}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- Meal plan -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-16">
    <div class="flex items-baseline justify-between flex-wrap gap-2 mb-5">
      <h2 class="font-display text-2xl font-bold text-ink-100">Meal templates</h2>
      <p class="text-xs text-ink-400">Rotate options across the week. Hit macros, not perfection.</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {mealPlan.map(m => (
        <article class="rounded-xl border border-ink-800 bg-gradient-to-br from-ink-900 to-ink-950 p-5">
          <div class="flex items-baseline justify-between gap-3">
            <h3 class="font-display text-lg font-bold text-ink-100">{m.meal}</h3>
            <p class="text-[11px] text-ink-300 font-mono-tnum">{m.macros}</p>
          </div>
          <ul class="mt-4 space-y-2">
            {m.options.map(opt => (
              <li class="flex items-start gap-2 text-sm text-ink-200">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-flame-500 shrink-0" aria-hidden="true"></span>
                <span>{opt}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <!-- Race target -->
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-20">
    <div class="rounded-2xl border border-ink-800 bg-gradient-to-r from-flame-500/10 via-ink-900 to-volt-400/10 p-6 sm:p-10">
      <div class="grid lg:grid-cols-3 gap-6 items-center">
        <div class="lg:col-span-2">
          <p class="text-xs uppercase tracking-widest text-volt-400 font-semibold">Block goal</p>
          <h2 class="mt-2 font-display text-3xl font-bold text-ink-100 tracking-tight">Sub-3:00 marathon · Oct 11, 2026</h2>
          <p class="mt-3 text-ink-300 max-w-2xl">Average target pace 4:15/km. The plan biases volume in weeks 8–14, with a 3-week taper to race day.</p>
        </div>
        <div class="grid grid-cols-3 gap-3 font-mono-tnum text-center">
          <div class="rounded-lg bg-ink-900/80 border border-ink-800 px-3 py-3">
            <p class="text-[10px] uppercase tracking-wider text-ink-400 font-semibold">Weeks</p>
            <p class="mt-1 font-display text-2xl font-bold text-flame-400">11/18</p>
          </div>
          <div class="rounded-lg bg-ink-900/80 border border-ink-800 px-3 py-3">
            <p class="text-[10px] uppercase tracking-wider text-ink-400 font-semibold">Peak km</p>
            <p class="mt-1 font-display text-2xl font-bold text-flame-400">120</p>
          </div>
          <div class="rounded-lg bg-ink-900/80 border border-ink-800 px-3 py-3">
            <p class="text-[10px] uppercase tracking-wider text-ink-400 font-semibold">Race</p>
            <p class="mt-1 font-display text-2xl font-bold text-volt-400">3:00</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
