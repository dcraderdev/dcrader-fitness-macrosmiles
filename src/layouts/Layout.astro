---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  preloadFontWeights?: number[];
}

const { title, description = 'Macros + Miles — a run and nutrition log built for athletes. Daily runs, macro splits, weekly stats.' } = Astro.props;
const fullTitle = title === 'Macros + Miles' ? title : `${title} · Macros + Miles`;
const canonical = new URL(Astro.url.pathname, 'https://macrosmiles.dcrader.dev').toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#07090d" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" />
    <script src="/template-topheader.js" defer></script>
    <style>
      /* Offset for portfolio bar (#dcrader-th, 34px fixed top:0) injected by template-topheader.js */
      body { padding-top: 34px; }
    </style>
  </head>
  <body class="min-h-dvh flex flex-col">
    <a class="skip-link" href="#main">Skip to main content</a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
